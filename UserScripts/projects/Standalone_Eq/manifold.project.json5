{
  "name": "Standalone EQ8",
  "version": 1,
  "description": "8-band parametric EQ export target",
  "ui": {
    "root": "ui/main.ui.lua",
    "sharedShell": false
  },
  "plugin": {
    "view": {
      "defaultMode": "split",
      "compact": { "w": 236, "h": 220 },
      "split": { "w": 472, "h": 220 }
    },
    "osc": {
      "enabled": true,
      "queryEnabled": true,
      "basePort": 9020,
      "oscQueryPort": 9021
    },
    "params": [
      {
        "path": "/plugin/params/band/1/enabled",
        "internalPath": "/midi/synth/rack/eq/1/band/1/enabled",
        "type": "f",
        "min": 0,
        "max": 1,
        "default": 0,
        "hostParamId": "band_1_enabled",
        "hostParamName": "Band 1 Enabled",
        "hostParamKind": "bool",
        "description": "EQ band 1 enabled"
      },
      {
        "path": "/plugin/params/band/1/type",
